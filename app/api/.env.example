# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*
JWT_SECRET=change-me-in-production-please-32chars

# Logging
LOG_LEVEL=info
ENABLE_FILE_LOG=true
ENABLE_CONSOLE_LOG=true

# Swagger Documentation
ENABLE_SWAGGER=true

# JWT Configuration
JWT_EXPIRATION_TIME=24h
JWT_REFRESH_EXPIRATION_TIME=7d

# Password Security
BCRYPT_ROUNDS=12

# Rate Limiting
ENABLE_RATE_LIMIT=true
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
USE_REDIS_RATE_LIMIT=false

# Request Limits
MAX_REQUEST_SIZE=10mb
MAX_FILE_SIZE=5mb
REQUEST_TIMEOUT_MS=30000

# CORS Configuration
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Security
PROTECTED_ROLES=superadmin,admin

# Performance
ENABLE_COMPRESSION=true
ENABLE_API_VERSIONING=true
ENABLE_REQUEST_TIMEOUT=true

# Caching
CACHE_TTL=300
USE_REDIS_CACHE=false
REDIS_HOST=localhost
REDIS_PORT=6379

# Audit Configuration
AUDIT_MAX_PAYLOAD_SIZE=20480
AUDIT_IGNORED_ENTITIES=AuditLog,AuditLogEntity
AUDIT_IGNORED_ACTIONS=
AUDIT_EXCLUDED_FIELDS=password,refresh_token,access_token,secret,api_key

# Slack Notifications (Optional)
SLACK_WEBHOOK_URL=

# Email Notifications (Optional)
ENABLE_EMAIL_ALERTS=false
EMAIL_ALERT_RECIPIENT=admin@example.com

# API Key Authentication (optional — leave empty to disable)
# When set, protected routes require x-api-key header unless marked @ApiKeyPublic (login, register, logout)
# Health endpoints use API key only (no JWT): /api/v1/health, /liveness, /readiness
# Supports comma-separated keys for rotation: key1,key2
API_KEY=

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=dspuser
DB_PASSWORD=dsp_pass
DB_DATABASE=dsp
DB_SYNCHRONIZE=true
DB_CONNECTION_LIMIT=10
DB_MAX_IDLE=5
DB_IDLE_TIMEOUT=60000
DB_ACQUIRE_TIMEOUT=10000
DB_SSL=false
DB_MIGRATION_TABLE=migrations
