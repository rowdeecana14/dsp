@baseUrl = http://localhost:3000
@authToken = {{login.response.body.data.token}}
@study_instance_uid = 1.2.840.113619.2.55.3.604688175.827.1599878051.467
@series_id = 1.2.826.0.1.3680043.8.498.1.1.1.1.1.1
@viewer_state_id = {{saveViewerState.response.body.data.id}}
@measurement_id = {{createMeasurement.response.body.data.id}}
@image_id = wadors:https://d14fa38qiwhyfd.cloudfront.net/dicomweb/studies/{{study_instance_uid}}/series/{{series_id}}/instances/1.2.392.200036.9125.0.19950720093509/frames/1

### Auth - Login
# @name login
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "superadmin@example.com",
  "password": "change-me-strongly"
}

### Viewer State - Save (for viewer_state_id variable)
# @name saveViewerState
POST {{baseUrl}}/api/v1/viewer-state
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "study_instance_uid": "{{study_instance_uid}}",
  "mode": "dental",
  "theme": "dental",
  "viewport_layout": "2x2-dental",
  "selected_tooth": "36",
  "tooth_system": "FDI",
  "patient_id": "P001"
}

### Measurements - List (grouped by study → series)
GET {{baseUrl}}/api/v1/measurements?study_instance_uid={{study_instance_uid}}&page=1&limit=10&sort_by=label&sort_order=ASC
Authorization: Bearer {{authToken}}

### Measurements - List with filters
GET {{baseUrl}}/api/v1/measurements?study_instance_uid={{study_instance_uid}}&page=1&limit=10&sort_by=updated_at&sort_order=DESC&search=PA&dental_preset_id=pa-length&series_ids={{series_id}}
Authorization: Bearer {{authToken}}

### Measurements - List by viewer state
GET {{baseUrl}}/api/v1/measurements/viewer-state/{{viewer_state_id}}
Authorization: Bearer {{authToken}}

### Measurements - Create single
# @name createMeasurement
POST {{baseUrl}}/api/v1/measurements/create
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "study_instance_uid": "{{study_instance_uid}}",
  "viewer_state_id": "{{viewer_state_id}}",
  "label": "PA length",
  "value": "12.5",
  "unit": "mm",
  "tool": "Length",
  "type": "PA_LENGTH",
  "viewport": "top_left",
  "image_id": "{{image_id}}",
  "dental_preset_id": "pa-length",
  "series_id": "{{series_id}}",
  "captured_at": "2026-07-05T12:34:56.000Z",
  "coordinates": {
    "points": [[120, 200, 0], [300, 400, 0]],
    "frame_of_reference_uid": "1.2.3",
    "series_id": "{{series_id}}",
    "sop_instance_uid": "1.2.392.200036.9125.0.19950720093509",
    "referenced_image_id": "{{image_id}}",
    "display_set_instance_uid": "d3345a1b-85b6-e2cf-4b51-28f2f46823bb",
