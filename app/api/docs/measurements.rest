  }
}

### Measurements - Save bulk (studies schema, replace per study)
POST {{baseUrl}}/api/v1/measurements
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "studies": [
    {
      "study_instance_uid": "{{study_instance_uid}}",
      "series": [
        {
          "series_id": "{{series_id}}",
          "measurements": [
            {
              "label": "PA length",
              "value": "12.4 mm",
              "unit": "mm",
              "tool": "Length",
              "captured_at": "2026-07-05T12:34:56.000Z",
              "dental_preset_id": "pa-length",
              "viewer_state_id": "{{viewer_state_id}}",
              "type": "PA_LENGTH",
              "viewport": "top_left",
              "image_id": "{{image_id}}",
              "coordinates": {
                "points": [[120, 200, 0], [300, 400, 0]],
                "frame_of_reference_uid": "1.2.3",
                "series_id": "{{series_id}}",
                "sop_instance_uid": "1.2.392.200036.9125.0.19950720093509",
                "referenced_image_id": "{{image_id}}",
                "display_set_instance_uid": "d3345a1b-85b6-e2cf-4b51-28f2f46823bb",
                "dental_preset_id": "pa-length"
              }
            }
          ]
        }
      ]
    }
  ]
}

### Measurements - Save bulk (flat format)
POST {{baseUrl}}/api/v1/measurements
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "study_instance_uid": "{{study_instance_uid}}",
  "measurements": [
    {
      "label": "Canal angle",
      "value": "45 °",
      "unit": "°",
      "tool": "Angle",
      "captured_at": "2026-07-05T12:34:56.000Z",
      "dental_preset_id": "canal-angle",
      "type": "CANAL_ANGLE",
      "viewport": "top_right",
      "series_id": "{{series_id}}",
      "coordinates": {
        "points": [[10, 20, 0], [30, 40, 0]],
        "series_id": "{{series_id}}"
      }
    }
  ]
}

### Measurements - Update metadata (rename)
PATCH {{baseUrl}}/api/v1/measurements/{{measurement_id}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "action": "rename",
  "label": "PA length updated"
}

### Measurements - Update metadata (lock)
PATCH {{baseUrl}}/api/v1/measurements/{{measurement_id}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "action": "lock",
  "is_locked": true
}

### Measurements - Update metadata (visible)
PATCH {{baseUrl}}/api/v1/measurements/{{measurement_id}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "action": "visible"
}

### Measurements - Update metadata (hide)
PATCH {{baseUrl}}/api/v1/measurements/{{measurement_id}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "action": "hide"
}

### Measurements - Update full payload (value, coordinates, etc.)
PUT {{baseUrl}}/api/v1/measurements/{{measurement_id}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "label": "PA length",
  "value": "13.1",
  "unit": "mm",
  "tool": "Length",
  "type": "PA_LENGTH",
  "viewport": "top_left",
  "image_id": "{{image_id}}",
  "dental_preset_id": "pa-length",
  "coordinates": {
    "points": [[120, 200, 0], [310, 410, 0]],
    "series_id": "{{series_id}}",
    "referenced_image_id": "{{image_id}}"
  }
}

### Measurements - Bulk update
PATCH {{baseUrl}}/api/v1/measurements/bulk
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "ids": ["{{measurement_id}}"],
  "action": "lock",
  "is_locked": true
}

### Measurements - Delete
DELETE {{baseUrl}}/api/v1/measurements/{{measurement_id}}
Authorization: Bearer {{authToken}}

### Notes
# All request/response fields use snake_case.
# measurements table columns: id, study_instance_uid, series_id, user_id, viewer_state_id,
# label, value, unit, tool, dental_preset_id, type, viewport, image_id (VARCHAR 512),
# captured_at, coordinates, created_at, updated_at, ...
