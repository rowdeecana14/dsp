{
  "name": "@ohif/extension-dental",
  "version": "3.13.0-beta.110",
  "description": "Dental SaaS customization for OHIF Viewer - Practice Header, measurements palette, and dental hanging protocol",
  "author": "DSP",
  "license": "MIT",
  "main": "dist/ohif-extension-dental.umd.js",
