{
  "name": "@ohif/mode-dental",
  "version": "3.13.0-beta.110",
  "description": "Dental SaaS viewing mode with practice header, 2x2 hanging protocol, and measurement palette",
  "author": "DSP",
  "license": "MIT",
  "main": "dist/ohif-mode-dental.umd.js",
  "module": "src/index.ts",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development rspack build --config .webpack/webpack.dev.js --watch",
    "build": "cross-env NODE_ENV=production rspack build --config .webpack/webpack.prod.js",
    "build:package": "pnpm run build",
    "start": "pnpm run dev"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "dependencies": {
    "@babel/runtime": "7.29.7",
    "@cornerstonejs/core": "5.1.3",
    "@cornerstonejs/tools": "5.1.3",
    "@ohif/core": "workspace:*",
    "@ohif/extension-cornerstone": "workspace:*",
    "@ohif/extension-cornerstone-dicom-sr": "workspace:*",
    "@ohif/extension-default": "workspace:*",
    "@ohif/extension-dental": "workspace:*",
    "i18next": "17.3.1"
  },
  "devDependencies": {
    "cross-env": "7.0.3",
    "webpack-merge": "5.10.0"
  },
  "keywords": [
    "ohif-mode",
    "dental"
  ]
}
